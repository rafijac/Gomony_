{
    // See https://go.microsoft.com/fwlink/?linkid=830387 for more about launch configurations
    "version": "0.2.0",
    "compounds": [
        {
            "name": "Run Full App",
            "configurations": ["Python: Run Backend", "Vite: Run Frontend"]
        }
    ],
    "configurations": [
        {
            "name": "Python: Run Backend",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "backend.main:app",
                "--host", "127.0.0.1",
                "--port", "8001",
                "--reload"
            ],
            "jinja": true,
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "Vite: Run Frontend",
            "type": "pwa-node",
            "request": "launch",
            "cwd": "${workspaceFolder}/frontend",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "dev"],
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        }
    ]
}
